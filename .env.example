# LLM API endpoint
LLM_ENDPOINT=http://localhost:7999/v1/chat/completions
LLM_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Hermes Agent (optional — for workflow generation via Hermes)
HERMES_CONFIG_PATH=~/.hermes/config.yaml

# Database
DATABASE_URL=sqlite:///./data/esam.db

# Sandbox host (for NemoClaw integration)
ESAM_SSH_HOST=remote-host

# App
APP_ENV=development
